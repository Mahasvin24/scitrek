# Required: used to sign JWT access tokens
SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated origins allowed for browser requests (Next.js dev server by default)
CORS_ORIGINS=http://localhost:3000

# Optional: PEM strings for a fixed RSA key pair (otherwise keys/ is generated on first run)
# RSA_PRIVATE_KEY=
# RSA_PUBLIC_KEY=
