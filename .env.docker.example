# Copy to the repo root as .env before: docker compose up --build
#
# SECRET_KEY must be at least 32 characters for production JWT signing.
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# URL the browser uses to reach the API (host machine, not Docker service names).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed browser origins for CORS (comma-separated).
CORS_ORIGINS=http://localhost:3000
